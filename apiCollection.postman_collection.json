      "name": "createEmployee",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Helper function\r",
              "function randomInt(min, max) {\r",
              "    return Math.floor(Math.random() * (max - min + 1)) + min;\r",
              "}\r",
              "\r",
              "// Basic info\r",
              "let firstName = `FN_${randomInt(100,999)}`;\r",
              "let lastName = `LN_${randomInt(100,999)}`;\r",
              "let middleName = `MN_${randomInt(100,999)}`;\r",
              "\r",
              "// Email (always unique)\r",
              "let email = `user${Date.now()}@test.com`;\r",
              "\r",
              "// Phone (BD format realistic)\r",
              "let phone = `8801${randomInt(30000000,99999999)}`;\r",
              "\r",
              "// Staff ID\r",
              "let staffId = `${randomInt(100000,999999)}`;\r",
              "\r",
              "// Date functions\r",
              "let today = new Date().toISOString().split(\"T\")[0];\r",
              "\r",
              "// Better DOB (valid format)\r",
              "let year = randomInt(1990, 2002);\r",
              "let month = String(randomInt(1,12)).padStart(2,'0');\r",
              "let day = String(randomInt(1,28)).padStart(2,'0');\r",
              "let dob = `${year}-${month}-${day}`;\r",
              "\r",
              "// Address generator (reusable function)\r",
              "function generateAddress() {\r",
              "    return {\r",
              "        street_1: `Street_${randomInt(1,100)}`,\r",
              "        street_2: null,\r",
              "        country: \"Anguilla\",\r",
              "        state: \"East End\",\r",
              "        city: `City_${randomInt(1,50)}`,\r",
              "        zip: `ZIP_${randomInt(1000,9999)}`\r",
              "    };\r",
              "}\r",
              "\r",
              "let presentAddress = generateAddress();\r",
              "\r",
              "// Final body\r",
              "let requestBody = {\r",
              "    first_name: firstName,\r",
              "    middle_name: middleName,\r",
              "    last_name: lastName,\r",
              "    email: email,\r",
              "    phone: phone,\r",
              "    staff_id: staffId,\r",
              "\r",
              "    address_group: {\r",
              "        present_address: presentAddress,\r",
              "        permanent_address: {\r",
              "            same_as_present_address: true,\r",
              "            ...presentAddress\r",
              "        }\r",
              "    },\r",
              "\r",
              "    // Static IDs (keep as is)\r",
              "    employee_department_option_id: \"69391644740acf1e0c0373e7\",\r",
              "    employee_job_location_option_id: \"695dde14f97ee294810d9823\",\r",
              "    employee_status_option_id: \"692fdff8397c6c094bfb44a5\",\r",
              "    employee_gender_option_id: \"692fdffb397c6c094bfb44cd\",\r",
              "    employee_job_type_option_id: \"692fdff8397c6c094bfb44ab\",\r",
              "    employee_job_title_option_id: \"695dd83f49eaf632130950b3\",\r",
              "    manager_id: \"69ad216652b0b8a3d20a9eb2\",\r",
              "    who_to_contact_id: \"69ad214f52b0b8a3d20a9ea6\",\r",
              "    shift_option_id: \"692fe275f348e6963301e216\",\r",
              "\r",
              "    social_security_no: `SSN_${randomInt(10000,99999)}`,\r",
              "\r",
              "    work_function: \"remote\",\r",
              "\r",
              "    date_of_birth: dob,\r",
              "    hire_date: today,\r",
              "    joining_date: today,\r",
              "\r",
              "    employer_tasks: null,\r",
              "    joiner_tasks: null,\r",
              "\r",
              "    joiner_questions: {\r",
              "        \"695ddd1ce35026b82201d8b3\": {\r",
              "            \"0\": true,\r",
              "            \"1\": true\r",
              "        },\r",
              "        \"697b3ceef1f074b159047766\": {\r",
              "            \"0\": true\r",
              "        }\r",
              "    }\r",
              "};\r",
              "\r",
              "// Save\r",
              "pm.environment.set(\"requestBody\", JSON.stringify(requestBody));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse response JSON\r",
              "let res = pm.response.json();\r",
              "\r",
              "// ==================== Success Messages ====================\r",
              "pm.test(\"Success messages are correct\", () => {\r",
              "    // Check that 'success' exists\r",
              "    pm.expect(res.message).to.have.property(\"success\");\r",
              "\r",
              "    // Expected messages\r",
              "    const expectedMessages = [\r",
              "        \"Employee Added Successfully!\",\r",
              "        \"You’ve successfully added a new employee, you can find the employee onboarding updates on their profile.\"\r",
              "    ];\r",
              "\r",
              "    // Check length\r",
              "    pm.expect(res.message.success.length, \"Number of success messages\").to.eql(expectedMessages.length);\r",
              "\r",
              "    // Check each message\r",
              "    expectedMessages.forEach((msg, index) => {\r",
              "        pm.expect(\r",
              "            res.message.success[index],\r",
              "            `Expected message at index ${index} to be \"${msg}\", but got \"${res.message.success[index]}\"`\r",
              "        ).to.eql(msg);\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
