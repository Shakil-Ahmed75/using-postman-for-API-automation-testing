    {
      "name": "awardCreation",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Random name & note\r",
              "let name = \"test_\" + Math.floor(Math.random() * 10000);\r",
              "let note = \"note_\" + Date.now();\r",
              "\r",
              "// Dynamic award item\r",
              "let award_item = [\r",
              "    {\r",
              "        temp: \"Award_\" + Math.floor(Math.random() * 100),\r",
              "        currency: \"USD\",\r",
              "        gift_name: \"gift_\" + Math.floor(Math.random() * 1000),\r",
              "        price: Math.floor(Math.random() * 500) + 50\r",
              "    }\r",
              "];\r",
              "\r",
              "// Final JSON\r",
              "let requestBody = {\r",
              "    name: name,\r",
              "    note: note,\r",
              "    award_item: award_item\r",
              "};\r",
              "\r",
              "// Set to environment variable\r",
              "pm.environment.set(\"requestBody\", JSON.stringify(requestBody));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "let res = pm.response.json();\r",
              "let requestBody = JSON.parse(pm.environment.get(\"requestBody\"));\r",
              "\r",
              "// ==================== Name & Note ====================\r",
              "pm.test(\"Name and note match request body\", () => {\r",
              "    [\"name\", \"note\"].forEach(field => {\r",
              "        pm.expect(\r",
              "            res.data[field],\r",
              "            `Expected \"${field}\" to be \"${requestBody[field]}\", but got \"${res.data[field]}\"`\r",
              "        ).to.eql(requestBody[field]);\r",
              "    });\r",
              "});\r",
              "\r",
              "// ==================== Award Items ====================\r",
              "pm.test(\"Award items match request body\", () => {\r",
              "    let sentItems = requestBody.award_item || [];\r",
              "    let respItems = res.data.award_item || [];\r",
              "\r",
              "    pm.expect(respItems.length, \"Number of award items should match\").to.eql(sentItems.length);\r",
              "\r",
